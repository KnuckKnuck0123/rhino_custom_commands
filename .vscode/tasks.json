{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Rhino 8 Script",
            "type": "shell",
            "windows": {
                "command": "C:\\Program Files\\Rhino 8\\System\\rhinocode.exe"
            },
            "osx": {
                "command": "/Applications/Rhino 8.app/Contents/Resources/bin/rhinocode"
            },
            "args": [
                "script",
                "${file}"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}